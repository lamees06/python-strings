s=raw_input("Enter a string: ")
digits = 0
spaces = 0
alphabets = 0
for ch in s:
    if ch.isdigit():
        digits += 1
    elif ch.isspace():
        spaces += 1
    elif ch.isalpha():
        alphabets += 1
print "Number of digits: ",digits
print "Number of spaces: ",spaces
print "Number of alphabets: ",alphabets
